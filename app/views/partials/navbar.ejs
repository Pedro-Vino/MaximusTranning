<head>
    <link rel="stylesheet" href="/css/base.css">
    <script src="temas.js"></script>
</head>
<header>
  <section class="containernavbar">
    <a class="logo-container" href="/">
      <img src="/imagens/LogoSemFgrande.png" alt="Logo">
      <h2 class="nome-logo">MAXIMUS TRAINING</h2>
    </a>
    <button class="menu-toggle" onclick="toggleMenu()">☰</button>

    <nav class="navnavbar">
      <article class="menu-links">
        <a href="/" class="ativo">Início</a>
        <a href="/proposta">Nossa Proposta</a>
        <a href="/planos">Planos</a>
        <a href="/contato">Contato</a>
      </article>

      <!-- BOTÃO MODO CLARO/ESCURO -->
      <button class="btn-tema" id="btn-tema" onclick="toggleTema()" title="Alternar tema">
        <span id="tema-icone">☀️</span>
      </button>

      <% if (locals.aluno) { %>
        <div class="navbar-usuario">
          <a href="/perfil" class="navbar-perfil-btn">
            <img src="/<%= aluno.foto || 'imagens/alunos/default_user.png' %>" alt="Foto de perfil" class="navbar-foto">
            <span><%= aluno.nome.split(' ')[0] %></span>
          </a>
          <a href="/logout" class="botao-destaque botao-logout">Sair</a>
        </div>
      <% } else { %>
        <a href="/login" class="botao-destaque">Conta</a>
      <% } %>
    </nav>
  </section>
</header>
