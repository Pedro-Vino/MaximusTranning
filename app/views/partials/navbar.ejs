<head>
    <link rel="stylesheet" href="/css/base.css">
    <script>
        (function() {
            const tema = localStorage.getItem('tema');
            if (tema === 'claro') document.documentElement.setAttribute('data-tema', 'claro');
        })();
    </script>
</head>
<header>
  <section class="containernavbar">
    <a class="logo-container" href="/">
      <img src="/imagens/LogoSemFgrande.png" alt="Logo">
      <h2 class="nome-logo">MAXIMUS TRAINING</h2>
    </a>
    <button class="menu-toggle" onclick="toggleMenu()">☰</button>

    <nav class="navnavbar">
      <article class="menu-links">
        <a href="/" class="<%= paginaAtual === '/' ? 'ativo' : '' %>">Início</a>
        <a href="/proposta" class="<%= paginaAtual === '/proposta' ? 'ativo' : '' %>">Nossa Proposta</a>
        <a href="/contato" class="<%= paginaAtual === '/contato' ? 'ativo' : '' %>">Contato</a>
      </article>

      <button class="btn-tema" id="btn-tema" onclick="toggleTema()" title="Alternar tema">
        <span id="tema-icone">☀️</span>
      </button>

      <% if (locals.aluno) { %>
        <div class="navbar-usuario">
          <a href="/perfil" class="navbar-perfil-btn">
            <img src="/<%= aluno.foto || 'imagens/alunos/default_user.png' %>" alt="Foto de perfil" class="navbar-foto">
            <span><%= aluno.nome.split(' ')[0] %></span>
          </a>
          <a href="/logout" class="botao-destaque botao-logout">Sair</a>
        </div>
      <% } else { %>
        <a href="/login" class="botao-destaque">Conta</a>
      <% } %>
    </nav>
  </section>
</header>

<script>
function toggleMenu() {
    document.querySelector('.navnavbar').classList.toggle('menu-aberto');
}

function toggleTema() {
    const html = document.documentElement;
    const icone = document.getElementById('tema-icone');
    const temaAtual = html.getAttribute('data-tema');
    if (temaAtual === 'claro') {
        html.removeAttribute('data-tema');
        icone.textContent = '☀️';
        localStorage.setItem('tema', 'escuro');
    } else {
        html.setAttribute('data-tema', 'claro');
        icone.textContent = '🌙';
        localStorage.setItem('tema', 'claro');
    }
}

document.addEventListener('DOMContentLoaded', function() {
    const tema = localStorage.getItem('tema');
    const icone = document.getElementById('tema-icone');
    if (icone && tema === 'claro') icone.textContent = '🌙';
});
</script>