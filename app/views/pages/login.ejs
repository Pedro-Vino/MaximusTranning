<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login</title>

    <link rel="stylesheet" href="/css/base.css">
    <link rel="stylesheet" href="/css/login.css">
    <link rel="stylesheet" href="/css/erro.css">

    <link rel="icon" href="/imagens/LogoSemFgrande.png">

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/simple-notify@0.5.5/dist/simple-notify.min.css" />
    <script src="https://cdn.jsdelivr.net/npm/simple-notify@0.5.5/dist/simple-notify.min.js"></script>
    <script src="/js/notify.js"></script>
</head>
<body>

<%
const dadosForm = (typeof dados !== 'undefined' && dados) ? dados : { email: "", senha: "" };

const erroValidacao = { email: "", senha: "" };
const msgErroPag = { email: "", senha: "" };

if (typeof erros !== 'undefined' && erros && erros.errors) {
    erros.errors.forEach(function(e) {
        if (e.path === "email") {
            erroValidacao.email = "erro";
            msgErroPag.email = e.msg;
        }
        if (e.path === "senha") {
            erroValidacao.senha = "erro";
            msgErroPag.senha = e.msg;
        }
    });
}
%>
<%
const dadosNotificacaoSafe = typeof dadosNotificacao !== 'undefined' ? dadosNotificacao : null;
%>

<% if (dadosNotificacaoSafe) { %>
<script>
notify(
"<%= dadosNotificacaoSafe.titulo %>",
"<%= dadosNotificacaoSafe.mensagem %>",
"<%= dadosNotificacaoSafe.tipo %>",
"right top"
)
</script>
<% } %>

<header>
<%- include('../partials/navbar'); %> 
</header>

<main class="main_login">  
<section class="formulario">

<header class="form-header">
<article class="divisoria">
<img src="/imagens/LogoSemFgrande.png" class="logo">
<h1 class="titlelogo">Maximus Tranning</h1>
</article>
</header>

<%  if (typeof erro !== 'undefined' && erro) {  %>
<p style="color:#6200ff; text-align:center; margin-bottom:1rem;"><%= erro %></p>
<% } %>

<form method="post" action="/login">

<section class="form-group">
<label>Email</label>
<input 
    type="email" 
    name="email" 
    value="<%= dadosForm.email %>" 
    class="<%= erroValidacao.email %>" 
    placeholder="Digite seu email">
<span class="spanerro"><%= msgErroPag.email %></span>
</section>

<section class="form-group">
<label>Senha</label>

<div class="input-group">
<input 
    type="password" 
    name="senha" 
    id="senha"
    class="<%= erroValidacao.senha %>" 
    placeholder="Digite sua senha">

<button type="button" onclick="toggleSenha()" class="toggle-senha-btn1">
👁
</button>
</div>

<span class="spanerro"><%= msgErroPag.senha %></span>
<br>
<a href="/recuperar-senha">Esqueci a senha</a>
</section>

<footer class="form-footer">
<input type="submit" value="Entrar">

<nav>
<a href="/cadastro">Não tem conta? <b>Cadastre-se</b></a>
</nav>
</footer>

</form>

</section>
</main>

<%- include('../partials/footer'); %>

<script>
function toggleSenha() {
    const input = document.getElementById("senha");
    input.type = input.type === "password" ? "text" : "password";
}
</script>

</body>
</html>