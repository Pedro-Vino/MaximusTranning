<!DOCTYPE html>
<html lang="pt-br">
<head>

    <meta charset="UTF-8">

    <meta
      name="viewport"
      content="width=device-width, initial-scale=1.0"
    >

    <title>Suporte</title>

<style>

body{
    background: #000;
    color: white;
    font-family: Arial;
}

/* CHAT */

#chatbot{

    width: 400px;

    margin: 50px auto;

    background: #111;

    border-radius: 15px;

    padding: 15px;

    box-shadow: 0 0 20px rgba(0,0,0,0.5);
}

/* HEADER */

#chat-header{

    font-size: 22px;

    font-weight: bold;

    margin-bottom: 15px;

    color: #fff;
}

/* BODY */

#chat-body{

    height: 350px;

    overflow-y: auto;

    background: #1a1a1a;

    padding: 15px;

    border-radius: 12px;

    margin-bottom: 10px;
}

/* INPUT */

#chat-input{

    width: 100%;

    padding: 12px;

    border: none;

    border-radius: 10px;

    background: #222;

    color: white;

    outline: none;

    font-size: 14px;

    box-sizing: border-box;
}

#chat-input::placeholder{
    color: #999;
}

/* MENSAGEM USUÁRIO */

.msg-user{

    background: #d40000;

    color: white;

    padding: 12px;

    border-radius: 15px 15px 0 15px;

    margin: 12px 0;

    width: fit-content;

    max-width: 80%;

    margin-left: auto;

    font-size: 14px;

    line-height: 1.5;

    box-shadow: 0 0 10px rgba(0,0,0,0.4);

}

/* MENSAGEM BOT */

.msg-bot{

    background: #242424;

    color: white;

    padding: 12px;

    border-radius: 15px 15px 15px 0;

    margin: 12px 0;

    width: fit-content;

    max-width: 80%;

    font-size: 14px;

    line-height: 1.6;

    border: 1px solid #333;

    box-shadow: 0 0 10px rgba(0,0,0,0.4);

}

/* HORÁRIO */

.msg-user small,
.msg-bot small{

    display: block;

    margin-top: 5px;

    font-size: 11px;

    opacity: 0.7;

}

/* BOTÕES RÁPIDOS */

#quick-buttons{

    display: flex;

    flex-wrap: wrap;

    gap: 8px;

    margin-bottom: 14px;
}

#quick-buttons button{

    background: transparent;

    border: 1px solid #d40000;

    color: #fff;

    padding: 6px 14px;

    font-size: 12.5px;

    font-weight: 600;

    border-radius: 20px;

    cursor: pointer;

    transition: 0.2s;
}

#quick-buttons button:hover{
    background: #d40000;
}

/* RESPONSIVO */

@media(max-width: 500px){

    #chatbot{

        width: 90%;

        margin: 20px auto;
    }

}

</style>

</head>

<body>

<%- include('../partials/navbar'); %>

<div id="chatbot">

    <div id="chat-header">
        💬 Suporte Maximus
    </div>

    <div id="chat-body">

        <div id="quick-buttons">
            <button type="button" onclick="enviarPergunta('IMC')">IMC</button>
            <button type="button" onclick="enviarPergunta('Login')">Login</button>
            <button type="button" onclick="enviarPergunta('Cadastro')">Cadastro</button>
            <button type="button" onclick="enviarPergunta('Treinos')">Treinos</button>
            <button type="button" onclick="enviarPergunta('Perfil')">Perfil</button>
            <button type="button" onclick="enviarPergunta('Senha')">Senha</button>
            <button type="button" onclick="enviarPergunta('Progresso')">Progresso</button>
            <button type="button" onclick="enviarPergunta('Planos')">Planos</button>
            <button type="button" onclick="enviarPergunta('Horário de funcionamento')">Horários</button>
            <button type="button" onclick="enviarPergunta('Contato')">Contato</button>
        </div>

        <div class="msg-bot">
            Olá! Bem-vindo ao suporte da Maximus Training.<br><br>

            Escolha uma das opções acima ou digite sua dúvida abaixo. Você também pode perguntar sobre:<br>
            • Ativação de conta<br>
            • Foto de perfil<br>
            • Localização e horários<br>
            • Painel administrativo
        </div>

    </div>

    <input
        type="text"
        id="chat-input"
        placeholder="Digite sua dúvida..."
    >

</div>

<script>

const input = document.getElementById("chat-input");

const body = document.getElementById("chat-body");

function escapeHtml(texto){
    const div = document.createElement("div");
    div.textContent = texto;
    return div.innerHTML;
}

function enviarPergunta(texto){
    input.value = texto;
    input.dispatchEvent(new KeyboardEvent("keypress", { key: "Enter" }));
}

input.addEventListener("keypress", async function(e){

    if(e.key === "Enter"){

        const mensagem = input.value;

        if(mensagem.trim() == ""){
            return;
        }

        // horário
        const hora = new Date().toLocaleTimeString([], {
            hour: '2-digit',
            minute: '2-digit'
        });

        // mensagem usuário
        body.innerHTML += `

            <div class="msg-user">

                <b>Você:</b><br>
                ${escapeHtml(mensagem)}

                <small>${hora}</small>

            </div>

        `;

        input.value = "";

        body.scrollTop = body.scrollHeight;

        // digitando
        body.innerHTML += `

            <div class="msg-bot" id="digitando">
                 Digitando...
            </div>

        `;

        body.scrollTop = body.scrollHeight;

        // envia para backend
        const resposta = await fetch("/chat", {

            method: "POST",

            headers:{
                "Content-Type": "application/json"
            },

            body: JSON.stringify({
                mensagem: mensagem
            })

        });

        // delay fake
        await new Promise(resolve => setTimeout(resolve, 1000));

        const dados = await resposta.json();

        // remove digitando
        document.getElementById("digitando").remove();

        // resposta bot
        body.innerHTML += `

            <div class="msg-bot">

                <b> Bot:</b><br>
                ${dados.resposta}

                <small>${hora}</small>

            </div>

        `;

        body.scrollTop = body.scrollHeight;
    }

});

</script>

</body>
</html>