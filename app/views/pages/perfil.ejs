<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= aluno.nome %></title>
    <link rel="stylesheet" href="/css/perfil.css">
    <link rel="icon" href="imagens/LogoSemFgrande.png">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/simple-notify@0.5.5/dist/simple-notify.min.css" />
    <script src="https://cdn.jsdelivr.net/npm/simple-notify@0.5.5/dist/simple-notify.min.js"></script>
    <script src="/js/notify.js"></script>
</head>
<body>
    <% if (dadosNotificacao) { %>
        <script>
            notify("<%= dadosNotificacao.titulo %>","<%= dadosNotificacao.mensagem %>", "<%= dadosNotificacao.tipo %>", "right top")
        </script>
    <% } %>

    <header>
        <%- include('../partials/navbar'); %>
    </header>

    <main class="perfil-main">

        <section class="perfil-sidebar">
            <div class="perfil-foto-container">
                <img src="<%= aluno.foto || 'imagens/alunos/default_user.png' %>" alt="Foto de perfil" class="perfil-foto">
                <a href="/editar-perfil" class="perfil-editar-btn" title="Editar perfil">
                    <img src="imagens/1159633.png" alt="Editar">
                </a>
            </div>
            <h2 class="perfil-nome"><%= aluno.nome %></h2>
            <p class="perfil-email"><%= aluno.email %></p>

            <div class="perfil-treino-atual">
                <span class="label-vermelho">TREINO ATUAL:</span>
                <span class="valor-treino"><%= aluno.treino || 'A' %></span>
            </div>

            <ul class="perfil-stats-lista">
                <li>IDADE: <span><%= aluno.idade ? aluno.idade + ' anos' : '—' %></span></li>
                <li>PESO: <span><%= aluno.peso %></span></li>
                <li>ALTURA: <span><%= aluno.altura %></span></li>
                <li>IMC: <span><%= aluno.imc %> — <%= aluno.classificacaoImc %></span></li>
            </ul>
        </section>

        <section class="perfil-conteudo">
            <h1 class="perfil-bemvindo">BEM VINDO DE VOLTA, <%= aluno.nome.split(' ')[0].toUpperCase() %>!</h1>

            <div class="perfil-card-treinos">
                <span class="card-icone">🏋️</span>
                <div>
                    <strong>TREINOS NA SEMANA</strong>
                    <p>meta semanal: <%= aluno.metaSemanal || 5 %> treinos</p>
                </div>
            </div>

            <div class="perfil-cards-row">
                <div class="perfil-card">
                    <p class="card-label">ESTIMATIVA DE CALORIAS QUEIMADAS</p>
                    <p class="card-valor">🔥 <%= aluno.calorias || '0' %> <span>kcal</span></p>
                </div>
                <div class="perfil-card">
                    <p class="card-label">SEQUENCIA DE DIAS</p>
                    <p class="card-valor"><%= aluno.sequencia || 0 %> <span>dias</span></p>
                </div>
                <div class="perfil-card">
                    <p class="card-label">IMC ATUAL</p>
                    <p class="card-valor"><%= aluno.imc %> <span><%= aluno.classificacaoImc %></span></p>
                </div>
            </div>
             <div class="perfil-bottom-row">

                <div class="perfil-proximos-treinos">
                    <p class="card-label">PRÓXIMOS TREINOS</p>
                    <% 
                        const dias = ['DOMINGO','SEGUNDA-FEIRA','TERÇA-FEIRA','QUARTA-FEIRA','QUINTA-FEIRA','SEXTA-FEIRA','SÁBADO'];
                        const hoje = new Date();
                        const treinos_seq = ['A','B','C'];
                        const treino_atual_idx = treinos_seq.indexOf(aluno.treino || 'A');
                    %>
                    <% for(let i = 1; i <= 2; i++) { %>
                    <%
                        const proximoData = new Date(hoje);
                        proximoData.setDate(hoje.getDate() + i);
                        const diaNome = dias[proximoData.getDay()];
                        const proximoTreino = treinos_seq[(treino_atual_idx + i) % 3];
                        const dia = String(proximoData.getDate()).padStart(2,'0');
                        const mes = String(proximoData.getMonth()+1).padStart(2,'0');
                    %>
                    <div class="perfil-treino-item">
                        <div class="perfil-treino-barra"></div>
                        <div>
                            <strong><%= diaNome %></strong>
                            <p>Treino <%= proximoTreino %> — <%= dia %>/<%= mes %> 08:00</p>
                        </div>
                    </div>
                    <% } %>
                </div>

                <div class="perfil-logo-area">
                    <img src="/imagens/LogoSemFgrande.png" alt="Maximus Training" class="perfil-logo-img">
                    <p class="perfil-logo-txt">MAXIMUS TRAINING</p>
                    <span class="perfil-logo-sub">GYM CENTER</span>
                </div>

            </div>
        </section>

    </main>

    <%- include('../partials/footer'); %>
</body>
</html>