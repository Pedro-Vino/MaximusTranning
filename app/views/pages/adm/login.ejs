<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ADM Login</title>
    <link rel="stylesheet" href="/css/base.css">
    <link rel="stylesheet" href="/css/login.css">
    <link rel="icon" href="/imagens/LogoSemFgrande.png">
</head>
<body>
    <main class="main_login">
        <div class="container6">
            <div class="form-header">
                <h1>Área administrativa</h1>
                <p>Acesso restrito</p>
            </div>

            <% if (erro) { %>
                <p class="spanerro">* <%= erro %></p>
            <% } %>

            <form action="/adm/login" method="POST">
                <div class="form-group">
                    <label>ID</label>
                    <input type="text" name="id" value="<%= dados.id %>" required>
                </div>
                <div class="form-group">
                    <label>Senha</label>
                    <input type="password" name="senha" required>
                </div>
                <button type="submit" id="enviar_login">ENTRAR</button>
            </form>
        </div>
    </main>
</body>
</html>