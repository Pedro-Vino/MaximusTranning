<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Contato — Maximus Training</title>
    <link rel="stylesheet" href="/css/base.css">
    <link rel="stylesheet" href="/css/contato.css">
    <link rel="icon" href="/imagens/LogoSemFgrande.png">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/simple-notify@0.5.5/dist/simple-notify.min.css" />
    <script src="https://cdn.jsdelivr.net/npm/simple-notify@0.5.5/dist/simple-notify.min.js"></script>
    <script src="/js/notify.js"></script>
</head>
<body>
    <header><%- include('../partials/navbar'); %></header>

    <% if (typeof dadosNotificacao !== 'undefined' && dadosNotificacao) { %>
    <script>
        window.addEventListener('load', function() {
            notify("<%= dadosNotificacao.titulo %>","<%= dadosNotificacao.mensagem %>","<%= dadosNotificacao.tipo %>","right top")
        });
    </script>
    <% } %>

    <main class="contato-main">

        <section class="contato-hero">
            <h1>FALE CONOSCO</h1>
            <p>Tire suas dúvidas ou envie uma mensagem para nossa equipe</p>
        </section>

        <section class="contato-grid">

            <aside class="contato-info">
                <h2>Informações</h2>

                <div class="contato-item">
                    <span class="contato-icone">📍</span>
                    <div>
                        <strong>Endereço</strong>
                        <p>UNINOVE — Campus Memorial (Prédio D)</p>
                        <p>Rua Deputado Salvador Julianelli, s/n</p>
                        <p>Barra Funda, São Paulo - SP</p>
                        <p>CEP: 05001-900</p>
                    </div>
                </div>

                <div class="contato-item">
                    <span class="contato-icone">📱</span>
                    <div>
                        <strong>WhatsApp</strong>
                        <p>
                            <a href="https://wa.me/5511999873264" target="_blank">(11) 99987-3264</a>
                        </p>
                    </div>
                </div>

                <div class="contato-item">
                    <span class="contato-icone">✉️</span>
                    <div>
                        <strong>Email</strong>
                        <p>
                            <a href="mailto:pedro.ns@uni9.edu.br">pedro.ns@uni9.edu.br</a>
                        </p>
                    </div>
                </div>

                <div class="contato-item">
                    <span class="contato-icone">🕐</span>
                    <div>
                        <strong>Horário de funcionamento</strong>
                        <p>Segunda a Sexta: 06h — 22h</p>
                        <p>Sábado: 08h — 18h</p>
                        <p>Domingo: 08h — 14h</p>
                    </div>
                </div>
            </aside>
            <section class="contato-form-section">
                <h2>Enviar mensagem</h2>
                <form action="/contato" method="POST" class="contato-form">

                    <div class="contato-form-group">
                        <label>Nome</label>
                        <input type="text" name="nome" placeholder="Seu nome" required>
                    </div>

                    <div class="contato-form-group">
                        <label>Email</label>
                        <input type="email" name="email" placeholder="seuemail@gmail.com" required>
                    </div>

                    <div class="contato-form-group">
                        <label>Assunto</label>
                        <input type="text" name="assunto" placeholder="Assunto da mensagem" required>
                    </div>

                    <div class="contato-form-group">
                        <label>Mensagem</label>
                        <textarea name="mensagem" rows="5" placeholder="Escreva sua mensagem..." required></textarea>
                    </div>

                    <button type="submit" class="contato-btn" id="btn-contato" onclick="mostrarCarregando()">
                        ENVIAR MENSAGEM
                    </button>
                    <div id="loading-contato" style="display:none; text-align:center; margin-top:12px;">
                        <p style="color: var(--cinza_claro); font-size:14px;">⏳ Enviando mensagem...</p>
                    </div>
                </form>
            </section>

        </section>
        <section class="contato-mapa">
            <h2>Como chegar</h2>
            <iframe
                src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d1119.4389677859267!2d-46.66821268303508!3d-23.527586053467893!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x94ce5803c5832753%3A0x8b9b274a80cffaf8!2sUNINOVE%20-%20Campus%20Memorial%20(Pr%C3%A9dio%20D)!5e0!3m2!1spt-BR!2sbr!4v1777231741257!5m2!1spt-BR!2sbr" 
                width="100%" 
                height="450" 
                style="border:0;" 
                allowfullscreen="" 
                loading="lazy" 
                referrerpolicy="no-referrer-when-downgrade">
            </iframe>
        </section>

    </main>

    <%- include('../partials/footer'); %>

    <script>
    function mostrarCarregando() {
        setTimeout(() => {
            const btn = document.getElementById('btn-contato');
            const loading = document.getElementById('loading-contato');
            btn.disabled = true;
            btn.textContent = 'AGUARDE...';
            btn.style.opacity = '0.7';
            loading.style.display = 'block';
        }, 100);
    }
    </script>
</body>
</html>