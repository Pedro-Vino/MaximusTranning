<!DOCTYPE html>
<html lang="pt-br">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Calculando seu IMC</title>
  <link rel="stylesheet" href="/css/base.css">
  <link rel="icon" href="imagens/LogoSemFgrande.png">
  <style>
    .imc-main {
      display: flex;
      justify-content: center;
      align-items: center;
      min-height: 80vh;
      padding: 20px;
    }

    .imc-card {
      width: 100%;
      max-width: 480px;
      background: #111;
      border-radius: 10px;
      padding: 36px 30px;
      position: relative;
      box-shadow: 0 0 20px rgba(255, 0, 0, 0.15);
    }

    .imc-card::before {
      content: "";
      position: absolute;
      left: -15px;
      top: 0;
      width: 100%;
      height: 99%;
      background: var(--principal);
      border-radius: 5px;
      z-index: -1;
    }

    .imc-card h1 {
      font-size: 20px;
      font-weight: bold;
      text-transform: uppercase;
      color: var(--branco);
      border-left: 4px solid var(--vermelho);
      padding-left: 12px;
      margin-bottom: 28px;
    }

    .imc-inputs {
      display: flex;
      gap: 16px;
      margin-bottom: 8px;
    }

    .imc-group {
      flex: 1;
      display: flex;
      flex-direction: column;
      gap: 6px;
    }

    .imc-group label {
      font-size: 12px;
      font-weight: bold;
      text-transform: uppercase;
      color: var(--cinza_claro);
    }

    .imc-group input {
      width: 100%;
      padding: 12px 14px;
      background: #0d0d0d;
      border: 1px solid #333;
      border-radius: 6px;
      color: var(--branco);
      font-size: 16px;
      outline: none;
      transition: border 0.2s;
    }

    .imc-group input:focus {
      border-color: var(--vermelho);
    }

    .imc-btn {
      width: 100%;
      margin-top: 20px;
      padding: 14px;
      background: var(--vermelho);
      border: none;
      border-radius: 6px;
      color: var(--branco);
      font-size: 15px;
      font-weight: bold;
      text-transform: uppercase;
      cursor: pointer;
      transition: background 0.2s;
    }

    .imc-btn:hover {
      background: var(--principal_escura);
    }

    .imc-resultado {
      margin-top: 28px;
      text-align: center;
    }

    .imc-resultado span {
      font-size: 13px;
      color: var(--cinza_claro);
      text-transform: uppercase;
    }

    .imc-valor {
      font-size: 56px;
      font-weight: bold;
      color: var(--vermelho);
      margin-top: 6px;
      line-height: 1;
    }

    .imc-faixas {
      display: flex;
      gap: 8px;
      margin-top: 20px;
    }

    .imc-faixas div {
      flex: 1;
      padding: 10px 6px;
      border-radius: 6px;
      text-align: center;
      font-size: 12px;
      font-weight: bold;
      text-transform: uppercase;
      opacity: 0.35;
      transition: 0.3s;
    }

    #abaixo { background: #f59e0b; color: #000; }
    #ideal  { background: #22c55e; color: #000; }
    #acima  { background: #ef4444; color: #fff; }

    .ativo {
      opacity: 1 !important;
      transform: scale(1.05);
    }

    .imc-acoes {
      display: flex;
      flex-direction: column;
      gap: 10px;
      margin-top: 20px;
    }

    .btn-continuar {
      display: block;
      text-align: center;
      padding: 14px;
      border-radius: 6px;
      background: var(--vermelho);
      color: var(--branco);
      font-weight: bold;
      font-size: 15px;
      text-transform: uppercase;
      text-decoration: none;
      transition: background 0.2s;
    }

    .btn-continuar:hover {
      background: var(--principal_escura);
    }

    .btn-resetar {
      display: block;
      text-align: center;
      padding: 12px;
      border-radius: 6px;
      background: transparent;
      border: 1px solid #444;
      color: var(--cinza_claro);
      font-size: 14px;
      font-weight: bold;
      text-transform: uppercase;
      text-decoration: none;
      cursor: pointer;
      width: 100%;
      transition: 0.2s;
    }

    .btn-resetar:hover {
      border-color: var(--vermelho);
      color: var(--branco);
    }

    .imc-salvo-valor {
      font-size: 52px;
      font-weight: bold;
      color: var(--vermelho);
      margin-top: 8px;
    }
  </style>
</head>
<body>
  <header><%- include('../partials/navbar'); %></header>

  <main class="imc-main">
    <div class="imc-card">
      <h1>Calculando seu IMC</h1>

      <% if (typeof imcBanco !== 'undefined' && imcBanco) { %>

        <div class="imc-resultado">
          <span>Seu IMC salvo</span>
          <div class="imc-salvo-valor"><%= Number(imcBanco).toFixed(2) %></div>
        </div>

        <div class="imc-faixas">
          <div id="abaixo" class="<%= Number(imcBanco) < 18.5 ? 'ativo' : '' %>">Abaixo do peso</div>
          <div id="ideal"  class="<%= Number(imcBanco) >= 18.5 && Number(imcBanco) < 25 ? 'ativo' : '' %>">Peso ideal</div>
          <div id="acima"  class="<%= Number(imcBanco) >= 25 ? 'ativo' : '' %>">Acima do peso</div>
        </div>

        <div class="imc-acoes">
          <a href="/aguardar-verificacao" class="btn-continuar">Continuar →</a>
          <a href="/imc" class="btn-resetar">Calcular novamente</a>
        </div>

      <% } else { %>

        <div id="tela-calcular">
          <div class="imc-inputs">
            <div class="imc-group">
              <label>Peso (kg)</label>
              <input type="text" id="peso" placeholder="75">
            </div>
            <div class="imc-group">
              <label>Altura (cm)</label>
              <input type="text" id="altura" placeholder="170">
            </div>
          </div>
          <button class="imc-btn" onclick="calcularIMC()">Calcular IMC</button>

          <div class="imc-resultado">
            <span>Seu IMC</span>
            <div class="imc-valor" id="imc">--</div>
          </div>

          <div class="imc-faixas">
            <div id="abaixo">Abaixo do peso</div>
            <div id="ideal">Peso ideal</div>
            <div id="acima">Acima do peso</div>
          </div>
        </div>

        <div id="acoes" style="display:none;">
          <form action="/imc" method="POST" id="formSalvar">
            <input type="hidden" name="peso" id="peso-hidden">
            <input type="hidden" name="altura" id="altura-hidden">
            <div class="imc-acoes">
              <button type="submit" class="imc-btn">Salvar e ver resultado</button>
              <button type="button" onclick="resetar()" class="btn-resetar">Calcular novamente</button>
            </div>
          </form>
        </div>

      <% } %>
    </div>
  </main>

  <script>
    function calcularIMC() {
      const peso = parseFloat(document.getElementById('peso').value.replace(',', '.'))
      let alturaCm = parseFloat(document.getElementById('altura').value.replace(',', '.'))

      if (!peso || !alturaCm) return

      if (alturaCm < 3) alturaCm = alturaCm * 100
      if (alturaCm < 50 || alturaCm > 250) {
        alert('Altura inválida! Digite em cm (ex: 170) ou metros (ex: 1.70)')
        return
      }

      const alturaM = alturaCm / 100
      const imc = parseFloat((peso / (alturaM * alturaM)).toFixed(2))

      document.getElementById('imc').textContent = imc.toFixed(2)

      document.getElementById('abaixo').classList.remove('ativo')
      document.getElementById('ideal').classList.remove('ativo')
      document.getElementById('acima').classList.remove('ativo')

      if (imc < 18.5) document.getElementById('abaixo').classList.add('ativo')
      else if (imc < 25) document.getElementById('ideal').classList.add('ativo')
      else document.getElementById('acima').classList.add('ativo')

      document.getElementById('peso-hidden').value = peso
      document.getElementById('altura-hidden').value = alturaCm
      document.getElementById('acoes').style.display = 'block'
    }

    function resetar() {
      document.getElementById('imc').textContent = '--'
      document.getElementById('abaixo').classList.remove('ativo')
      document.getElementById('ideal').classList.remove('ativo')
      document.getElementById('acima').classList.remove('ativo')
      document.getElementById('acoes').style.display = 'none'
      document.getElementById('peso').value = ''
      document.getElementById('altura').value = ''
    }
  </script>
</body>
</html>