<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/css/base.css">
    <link rel="stylesheet" href="/css/home.css">
    <link rel="icon" href="/imagens/LogoSemFgrandeICO.ico">
    <title>Maximus Training</title>
</head>
<body>
  <%- include('../partials/navbar'); %>

  <% if (!aluno) { %>
  <main class="hero">
    <section class="hero-texto">
      <h1>SEU NOVO PONTO<br>DE PARTIDA<br>PARA FORÇA,<br>SAÚDE E<br>PERFORMANCE.</h1>
      <p>Sistema completo para gestão de academias, treinos em um só lugar.</p>
      <article class="hero-botoes">
        <a href="#" class="btn-vermelho">DESCUBRA</a>
        <a href="/proposta" class="btn-borda">NOSSA PROPOSTA</a>
      </article>
    </section>

  </main>
  <% } %>

  <% if (aluno) { %>
<section class="home-logado">
  <h2 class="home-bemvindo">
    BEM VINDO DE VOLTA, <%= aluno.nome.split(' ')[0].toUpperCase() %>!
  </h2>

  <% if (treinoAtual) { %>

    <div class="home-treinos-titulo">
      <h3>SEU TREINO DE HOJE — DIA <%= dia %></h3>
      <span class="home-categoria home-categoria--<%= aluno.categoria %>">
        <%= aluno.categoria === 'abaixo' ? 'Abaixo do peso'
          : aluno.categoria === 'ideal'  ? 'Peso ideal'
          : 'Acima do peso' %>
      </span>
    </div>

    <div class="home-treino-card home-treino-card--destaque">
      <h3>TREINO <%= treino_atual %></h3>
      <p class="treino-musculo"><%= treinoAtual.musculo %></p>
      <p class="treino-descricao">
        <%- treinoAtual.descricao.split(',').join('<br>') %>
      </p>

      <form action="/treino/concluir" method="POST">
        <input type="hidden" name="treino_nome" value="<%= treino_atual %>">
        <input type="hidden" name="categoria" value="<%= treinoAtual.categoria %>">
        <button type="submit" class="btn-concluir">
          CONCLUIR TREINO <%= treino_atual %>
            <span class="btn-proximo">
              próximo: 
              <%= treino_atual === 'C' ? 'Treino A (novo ciclo)' : 'Treino ' + (treino_atual === 'A' ? 'B' : 'C') %>
            </span>
        </button>
      </form>
    </div>

  <% } else { %>
    <div class="home-sem-imc">
      <p>Complete seu IMC para receber treinos personalizados.</p>
      <a href="/imc" class="btn-imc">Calcular IMC agora</a>
    </div>
  <% } %>

</section>
<% } %>

  <%- include('../partials/footer'); %>
  
</body>
</html>