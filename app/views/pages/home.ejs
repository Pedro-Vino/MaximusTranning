<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/css/base.css">
    <link rel="stylesheet" href="/css/home.css">
    <link rel="icon" href="/imagens/LogoSemFgrandeICO.ico">
    <title>Maximus Training</title>
</head>
<body>
  <%- include('../partials/navbar'); %>

  <% if (!aluno) { %>
  <main class="hero">
    <section class="hero-texto">
      <h1>SEU NOVO PONTO<br>DE PARTIDA<br>PARA FORÇA,<br>SAÚDE E<br>PERFORMANCE.</h1>
      <p>Sistema completo para gestão de academias, treinos em um só lugar.</p>
      <article class="hero-botoes">
        <a href="#" class="btn-vermelho">DESCUBRA</a>
        <a href="/proposta" class="btn-borda">NOSSA PROPOSTA</a>
      </article>
    </section>
    <section class="hero-imagem"></section>
  </main>
  <% } %>

  <% if (aluno) { %>
  <section class="home-logado">
    <h2 class="home-bemvindo">
      BEM VINDO DE VOLTA, <%= aluno.nome.split(' ')[0].toUpperCase() %>!
    </h2>

    <% if (treinos.length > 0) { %>
      <div class="home-treinos-titulo">
        <h3>TREINOS RECOMENDADOS PARA VOCÊ</h3>
        <span class="home-categoria home-categoria--<%= aluno.categoria %>">
          <%= aluno.categoria === 'abaixo' ? 'Abaixo do peso'
            : aluno.categoria === 'ideal'  ? 'Peso ideal'
            : 'Acima do peso' %>
        </span>
      </div>
      <div class="home-treinos-grid">
        <% treinos.forEach(treino => { %>
          <div class="home-treino-card">
            <h3>TREINO <%= treino.nome %></h3>
            <p class="treino-musculo"><%= treino.musculo %></p>
            <p class="treino-descricao"><%= treino.descricao %></p>
          </div>
        <% }) %>
      </div>
    <% } else { %>
      <div class="home-sem-imc">
        <p>Complete seu IMC para receber treinos personalizados.</p>
        <a href="/imc" class="btn-imc">Calcular IMC agora</a>
      </div>
    <% } %>
  </section>
  <% } %>

</body>
</html>