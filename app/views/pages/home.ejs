<!DOCTYPE html>
<html lang="pt-br">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <link rel="stylesheet" href="/css/base.css">
  <link rel="stylesheet" href="/css/home.css">
  <link rel="stylesheet" href="/css/chatbot.css">

  <link rel="icon" href="/imagens/LogoSemFgrandeICO.ico">

  <title>Maximus Training</title>
</head>

<body>

  <%- include('../partials/navbar'); %>

  <% if (!aluno) { %>

    <main class="hero">

      <section class="hero-texto">
        <h1>
          SEU NOVO PONTO<br>
          DE PARTIDA<br>
          PARA FORÇA,<br>
          SAÚDE E<br>
          PERFORMANCE.
        </h1>

        <p>
          Sistema completo para gestão de academias, treinos em um só lugar.
        </p>

        <article class="hero-botoes">
          <a href="/login" class="btn-vermelho">
            DESCUBRA
          </a>

          <a href="/proposta" class="btn-borda">
            NOSSA PROPOSTA
          </a>
        </article>

      </section>

      <section class="hero-imagem"></section>

    </main>

  <% } %>

  <% if (aluno) { %>

    <section class="home-logado">

      <h2 class="home-bemvindo">
        BEM VINDO DE VOLTA,
        <%= aluno.nome.split(' ')[0].toUpperCase() %>!
      </h2>

      <% if (treinoAtual) { %>

        <div class="home-treinos-titulo">

          <h3>
            SEU TREINO DE HOJE — DIA <%= aluno.sequencia + 1 %>
          </h3>

          <span class="home-categoria home-categoria--<%= aluno.categoria %>">

            <%= aluno.categoria === 'abaixo'
              ? 'Abaixo do peso'
              : aluno.categoria === 'ideal'
              ? 'Peso ideal'
              : 'Acima do peso'
            %>

          </span>

        </div>

        <div class="home-treino-destaque">

          <h3>
            TREINO <%= treinoAtual.nome %>
          </h3>

          <p class="treino-musculo">
            <%= treinoAtual.musculo %>
          </p>

          <hr style="border-color:#222; margin: 10px 0;">

          <% treinoAtual.descricao.split(',').forEach(item => { %>

            <p class="treino-desc-item">
              <%= item.trim() %>
            </p>

          <% }) %>

          <% if (!treinouHoje) { %>

            <form action="/concluir-treino" method="POST">

              <input type="hidden" name="treino_nome" value="<%= treinoAtual.nome %>">
              <input type="hidden" name="categoria" value="<%= aluno.categoria %>">

              <button type="submit" class="btn-concluir">

                CONCLUIR TREINO <%= treinoAtual.nome %>

                <span>
                  próximo:
                  Treino
                  <%= treinoAtual.nome === 'C'
                    ? 'A (novo ciclo)'
                    : treinoAtual.nome === 'A'
                    ? 'B'
                    : 'C'
                  %>
                </span>

              </button>

            </form>

          <% } else { %>

            <div class="btn-treino-feito">
              ✅ TREINO CONCLUÍDO HOJE!
              <span>Volte amanhã para o próximo treino</span>
            </div>

          <% } %>

        </div>

      <% } else { %>

        <div class="home-sem-imc">

          <p>
            Complete seu IMC para receber treinos personalizados.
          </p>

          <a href="/imc" class="btn-imc">
            Calcular IMC agora
          </a>

        </div>

      <% } %>

    </section>

  <% } %>

  <%- include('../partials/footer'); %>

  <!-- BOTÃO FLUTUANTE -->
  <button id="chat-toggle" aria-label="Abrir chat de suporte">
    <svg width="26" height="26" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
      <path d="M12 2C6.48 2 2 5.94 2 10.8c0 2.68 1.42 5.07 3.64 6.7-.12.98-.5 2.6-1.44 3.98a.5.5 0 0 0 .58.75c2.06-.56 3.6-1.5 4.46-2.1.87.2 1.78.31 2.76.31 5.52 0 10-3.94 10-8.8S17.52 2 12 2Z"/>
    </svg>
  </button>

  <!-- CHAT -->
  <div id="chatbot" role="dialog" aria-label="Chat de suporte">

    <div id="chat-header">
      <div class="chat-header-info">
        <span class="chat-status-dot" aria-hidden="true"></span>
        <div class="chat-header-texto">
          <strong>Suporte Maximus Training</strong>
          <span class="chat-subtitle">Online agora</span>
        </div>
      </div>
      <button id="fechar-chat" aria-label="Fechar chat">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
          <path d="M6 6l12 12M18 6L6 18"/>
        </svg>
      </button>
    </div>

    <div id="chat-body">
      <div id="quick-buttons">
        <button type="button" onclick="enviarPergunta('IMC')">IMC</button>
        <button type="button" onclick="enviarPergunta('Login')">Login</button>
        <button type="button" onclick="enviarPergunta('Cadastro')">Cadastro</button>
        <button type="button" onclick="enviarPergunta('Treinos')">Treinos</button>
        <button type="button" onclick="enviarPergunta('Perfil')">Perfil</button>
        <button type="button" onclick="enviarPergunta('Senha')">Senha</button>
        <button type="button" onclick="enviarPergunta('Progresso')">Progresso</button>
        <button type="button" onclick="enviarPergunta('Planos')">Planos</button>
        <button type="button" onclick="enviarPergunta('Horário de funcionamento')">Horários</button>
        <button type="button" onclick="enviarPergunta('Contato')">Contato</button>
      </div>
    </div>

    <form id="chat-form" autocomplete="off">
      <input
        type="text"
        id="chat-input"
        placeholder="Digite sua dúvida..."
        autocomplete="off"
      >
      <button type="submit" id="chat-enviar" aria-label="Enviar mensagem">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M3 11l18-8-8 18-2.5-6.5L3 11z"/>
        </svg>
      </button>
    </form>

  </div>

  <!-- JS DO CHATBOT -->
  <script src="/js/chatbot.js"></script>

</body>
</html>