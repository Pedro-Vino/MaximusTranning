    <main class="main_login">

    <section class="container6">

        <header class="form-header">

            <article class="divisoria">
                <img src="/imagens/LogoSemFgrande.png" alt="Logo" class="logo">
                <h1 class="titlelogo">Maximus Tranning</h1>
            </article>
            <h1>Cadastre-se</h1>
        </header>

        <form id="signup" method="post" action="/cadastrar">

            <fieldset>
                <section class="form-group">
                    <label for="nome">Nome</label>
                    <input type="text" name="nome" id="nome"
                        value="<%= dados.nome %>"
                        class="<%= erroValidacao.nome %>">
                    <span class="spanerro"><%= msgErroPag.nome %></span>
                </section>

                <section class="form-group">
                    <label for="email">Email</label>
                    <input type="email" name="email" id="email"
                        value="<%= dados.email %>"
                        class="<%= erroValidacao.email %>">
                    <span class="spanerro"><%= msgErroPag.email %></span>
                </section>

            </fieldset>

            <fieldset>

                <section class="form-group">
                    <label for="senha">Senha</label>

                    <article class="input-group">
                        <input type="password" name="senha" id="senha"
                            value="<%= dados.senha %>"
                            class="<%= erroValidacao.senha %>">

                        <button type="button" id="toggleSenha"
                            class="toggle-senha-btn2"
                            aria-label="Mostrar senha">👁️</button>
                    </article>
                </section>

                <aside class="content">
                    <p>Senha deve conter:</p>
                    <ul class="requirement-list">
                        <li><i class="fa-solid fa-circle"></i> mínimo 8 caracteres</li>
                        <li><i class="fa-solid fa-circle"></i> 1 número</li>
                        <li><i class="fa-solid fa-circle"></i> 1 minúscula</li>
                        <li><i class="fa-solid fa-circle"></i> 1 símbolo </li>
                        <li><i class="fa-solid fa-circle"></i> 1 maiúscula </li>
                    </ul>
                </aside>

                <section class="form-group">
                    <label for="repsenha">Confirme a senha</label>

                    <article class="input-group">
                        <input type="password" name="repsenha" id="repsenha"
                            value="<%= dados.repsenha %>"
                            class="<%= erroValidacao.repsenha %>">

                        <button type="button" id="ctoggleSenha"
                            class="toggle-senha-btn3"
                            aria-label="Mostrar senha">👁️</button>
                    </article>

                    <span class="spanerro"><%= msgErroPag.repsenha %></span>
                </section>

            </fieldset>

            <footer class="form-footer">
                <input type="submit" id="enviar_login" value="Cadastrar">
                <nav>
                    <a href="/login">Já possui uma conta? <b>Entrar</b></a>
                </nav>
            </footer>

        </form>

    </section>

</main>
    <%- include('../partials/footer'); %>
</body>
</html>